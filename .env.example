# External PostgreSQL database used by local development, Vercel Development,
# and Vercel Preview. Do not point hosted deployments at localhost.
DATABASE_URL="postgresql://user:password@your-postgres-host:5432/aicodingblog?sslmode=require"

# Public origin used for metadata, feeds, sitemap output, and OG URLs.
# Local development usually uses http://localhost:3000.
# Hosted preview/development should use the exact deployment origin for that environment.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stable secret used to sign short-lived MFA challenge tokens.
# Required for hosted environments so login + MFA verification can succeed across instances.
MFA_TOKEN_SECRET="replace-with-a-long-random-secret"

# Auth cookies are host-only by design.
# - localhost sessions stay on localhost.
# - Vercel Development sessions stay on that dev origin.
# - Preview sessions stay on the exact preview hostname that issued them.
# - Sessions are not shared across different preview URLs or aliases.

# Legacy variables retained only for older Docker/container notes.
# They are not used by the current runtime auth flow.
# NEXTAUTH_URL=""
# NEXTAUTH_SECRET=""
